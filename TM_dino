<!DOCTYPE html>
<html lang="zh-HK">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Dino Run - TM Style</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Roboto', sans-serif;
            background-color: #f0f2f5;
            margin: 0;
            overflow: hidden; /* 防止捲動 */
        }

        /* --- 1. 遊戲區域 (全螢幕或置中) --- */
        #game-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            flex-direction: column;
        }

        canvas {
            background: white;
            border: 1px solid #ddd;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            max-width: 100%;
        }

        /* --- 2. 啟動選單 (初始畫面) --- */
        #setup-panel {
            background: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
            text-align: center;
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            z-index: 200;
            width: 400px;
        }
        
        .input-group { margin-bottom: 20px; text-align: left; }
        label { font-weight: 500; display: block; margin-bottom: 8px; color: #3c4043; }
        input, select { 
            width: 100%; padding: 12px; 
            border: 1px solid #dadce0; border-radius: 6px; 
            box-sizing: border-box; font-size: 14px;
        }
        button#start-btn {
            background-color: #1a73e8; color: white;
            padding: 12px 24px; border: none; border-radius: 24px;
            font-size: 16px; font-weight: 500; cursor: pointer;
            width: 100%; transition: background 0.2s;
        }
        button#start-btn:hover { background-color: #1557b0; }
        button:disabled { background-color: #dadce0; color: #80868b; cursor: default; }

        /* --- 3. Teachable Machine 風格介面 (左上角) --- */
        #tm-interface {
            position: fixed;
            top: 20px;
            left: 20px;
            width: 300px;
            background: white;
            border-radius: 8px;
            box-shadow: 0 1px 2px 0 rgba(60,64,67,0.3), 0 2px 6px 2px rgba(60,64,67,0.15);
            padding: 0;
            z-index: 100;
            display: none; /* 一開始隱藏 */
        }

        .tm-header {
            padding: 16px 20px;
            border-bottom: 1px solid #e8eaed;
            font-size: 16px;
            font-weight: 500;
            color: #202124;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* 模擬 Toggle 開關 */
        .toggle-switch {
            width: 36px; height: 20px;
            background: #bdcefc; /* ON color light */
            border-radius: 20px;
            position: relative;
            cursor: default;
        }
        .toggle-knob {
            width: 16px; height: 16px;
            background: #1a73e8; /* ON color dark */
            border-radius: 50%;
            position: absolute;
            top: 2px; right: 2px;
        }

        .tm-body {
            padding: 20px;
        }

        .webcam-box {
            width: 100%;
            height: 200px; /* 正方形或長方形視窗 */
            background: #f8f9fa;
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            position: relative;
        }
        
        .webcam-box canvas {
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: none;
            box-shadow: none;
        }

        .output-label {
            font-size: 14px;
            color: #5f6368;
            margin-bottom: 10px;
            font-weight: 500;
        }

        /* 類別條狀圖列表 */
        .class-row {
            display: flex;
            align-items: center;
            margin-bottom: 8px;
            font-size: 14px;
        }
        
        .class-name {
            width: 70px;
            color: #3c4043;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            text-align: right;
            margin-right: 10px;
        }

        .bar-bg {
            flex-grow: 1;
            height: 24px;
            background-color: #f1f3f4; /* 淺灰底 */
            border-radius: 4px;
            overflow: hidden;
            position: relative;
        }

        .bar-fill {
            height: 100%;
            width: 0%;
            background-color: #e8eaed;
            transition: width 0.1s linear, background-color 0.2s;
            border-radius: 4px;
        }

        .class-percent {
            width: 40px;
            text-align: right;
            color: #5f6368;
            font-size: 12px;
            margin-left: 8px;
        }

        /* 提示文字 */
        .hint {
            margin-top: 15px;
            font-size: 12px;
            color: #d93025;
            text-align: center;
            background: #fce8e6;
            padding: 8px;
            border-radius: 4px;
        }

    </style>
</head>
<body>

    <div id="setup-panel">
        <h2 style="color: #202124;">🦖 AI Dino Run</h2>
        <div class="input-group">
            <label>模型類型 (Project Type)</label>
            <select id="model-type">
                <option value="image">Image Project (圖像)</option>
                <option value="pose">Pose Project (姿態)</option>
            </select>
        </div>
        <div class="input-group">
            <label>Teachable Machine 模型連結</label>
            <input type="text" id="model-url" placeholder="https://teachablemachine.withgoogle.com/models/..." />
        </div>
        <button id="start-btn" onclick="init()">載入模型並開始 (Load Model)</button>
        <p id="status-msg" style="margin-top: 15px; color: #5f6368; font-size: 14px;"></p>
    </div>

    <div id="tm-interface">
        <div class="tm-header">
            <span>Preview this model live</span>
            <div style="display: flex; align-items: center; gap: 8px;">
                <span style="font-size: 12px; color: #5f6368;">Input ON</span>
                <div class="toggle-switch"><div class="toggle-knob"></div></div>
            </div>
        </div>
        <div class="tm-body">
            <div class="webcam-box" id="webcam-container">
                </div>
            
            <div class="output-label">Output</div>
            <div id="class-list"></div>

            <div class="hint">
                💡 觸發動作: <b>"A"</b>
            </div>
        </div>
    </div>

    <div id="game-wrapper">
        <canvas id="gameCanvas" width="800" height="300"></canvas>
        <h3 id="game-score" style="margin-top: 10px; color: #3c4043;">Score: 0</h3>
        <p style="color: #5f6368; font-size: 14px;">(點擊畫面或按 "R" 重新開始遊戲)</p>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@1.3.1/dist/tf.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@teachablemachine/image@0.8/dist/teachablemachine-image.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@teachablemachine/pose@0.8/dist/teachablemachine-pose.min.js"></script>

    <script>
        // --- 變數宣告 ---
        let model, webcam, maxPredictions, modelType;
        let gameRunning = false;
        let isGameOver = false;
        
        // 遊戲物件
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');
        let dino = { x: 50, y: 220, w: 40, h: 40, dy: 0, jumpPower: -15, grounded: true };
        let obstacle = { x: 800, y: 230, w: 30, h: 30, speed: 6 };
        let gravity = 0.8;
        let score = 0;
        let animationId;

        // 顏色庫 (模仿 Teachable Machine 的配色)
        const barColors = ["#db4437", "#f4b400", "#0f9d58", "#4285f4", "#ab47bc", "#00acc1"];

        // --- 初始化 (載入模型) ---
        async function init() {
            if (gameRunning) return;

            const urlInput = document.getElementById('model-url').value;
            modelType = document.getElementById('model-type').value;
            const btn = document.getElementById('start-btn');
            const statusMsg = document.getElementById('status-msg');

            if (!urlInput.startsWith("http")) {
                alert("連結格式錯誤！請確認是以 http 開頭");
                return;
            }

            btn.disabled = true;
            statusMsg.innerText = "正在讀取模型與啟動鏡頭...";

            // 1. 載入模型 (如果還沒載入過)
            if (!model) {
                try {
                    const modelURL = urlInput + "model.json";
                    const metadataURL = urlInput + "metadata.json";

                    if (modelType === "image") {
                        model = await tmImage.load(modelURL, metadataURL);
                        webcam = new tmImage.Webcam(280, 200, true); // 配合 CSS 寬度
                    } else {
                        model = await tmPose.load(modelURL, metadataURL);
                        webcam = new tmPose.Webcam(280, 200, true);
                    }
                    
                    maxPredictions = model.getTotalClasses();

                    // 2. 啟動鏡頭
                    await webcam.setup();
                    await webcam.play();
                    window.requestAnimationFrame(loop);

                    // 3. 設置 UI (將鏡頭放入左上角的卡片中)
                    const wcContainer = document.getElementById('webcam-container');
                    wcContainer.innerHTML = "";
                    wcContainer.appendChild(webcam.canvas);

                    // 4. 動態生成 Output Bars
                    createClassBars(model.getClassLabels());

                } catch (e) {
                    alert("模型載入失敗！請檢查連結。\n" + e);
                    btn.disabled = false;
                    statusMsg.innerText = "載入失敗";
                    model = null;
                    return;
                }
            }

            // 5. 切換畫面
            document.getElementById('setup-panel').style.display = 'none';
            document.getElementById('tm-interface').style.display = 'block';

            // 6. 開始遊戲
            resetGame();
        }

        // --- 動態建立 UI 條狀圖 ---
        function createClassBars(labels) {
            const list = document.getElementById('class-list');
            list.innerHTML = ""; // 清空
            
            labels.forEach((label, index) => {
                const color = barColors[index % barColors.length];
                
                const row = document.createElement('div');
                row.className = 'class-row';
                row.innerHTML = `
                    <div class="class-name" title="${label}">${label}</div>
                    <div class="bar-bg">
                        <div class="bar-fill" id="bar-${index}" style="background-color: ${color};"></div>
                    </div>
                    <div class="class-percent" id="percent-${index}">0%</div>
                `;
                list.appendChild(row);
            });
        }

        // --- 核心循環 ---
        async function loop() {
            if (webcam) {
                webcam.update();
                await predict();
            }
            window.requestAnimationFrame(loop);
        }

        // --- AI 預測與 UI 更新 ---
        async function predict() {
            if (!model) return;

            let prediction;
            if (modelType === "image") {
                prediction = await model.predict(webcam.canvas);
            } else {
                const { pose, posenetOutput } = await model.estimatePose(webcam.canvas);
                prediction = await model.predict(posenetOutput);
            }

            // 遍歷所有類別，更新 UI
            let jumpTriggered = false;

            for (let i = 0; i < maxPredictions; i++) {
                const p = prediction[i];
                const score = p.probability.toFixed(2);
                const percent = Math.round(p.probability * 100) + "%";
                
                // 更新條狀圖寬度與文字
                const bar = document.getElementById(`bar-${i}`);
                const txt = document.getElementById(`percent-${i}`);
                if (bar && txt) {
                    bar.style.width = percent;
                    txt.innerText = percent;
                    
                    // 高亮效果：如果信心 > 80%，讓顏色更鮮豔，否則變淡
                    bar.style.opacity = p.probability > 0.1 ? 1 : 0.3;
                }

                // 檢查是否觸發跳躍 (類別名稱為 "A" 且 信心 > 0.85)
                if (p.className === "A" && p.probability > 0.85) {
                    jumpTriggered = true;
                }
            }

            if (jumpTriggered) {
                jump();
            }
        }

        // --- 遊戲邏輯 ---
        function resetGame() {
            gameRunning = true;
            isGameOver = false;
            score = 0;
            obstacle.x = 800;
            obstacle.speed = 6;
            dino.y = 220;
            dino.dy = 0;
            dino.grounded = true;
            requestAnimationFrame(updateGame);
        }

        function jump() {
            if (dino.grounded && gameRunning && !isGameOver) {
                dino.dy = dino.jumpPower;
                dino.grounded = false;
            }
        }

        function updateGame() {
            if (!gameRunning) return;

            ctx.clearRect(0, 0, canvas.width, canvas.height);

            // 地板
            ctx.beginPath();
            ctx.moveTo(0, 260);
            ctx.lineTo(800, 260);
            ctx.strokeStyle = "#5f6368";
            ctx.lineWidth = 2;
            ctx.stroke();

            // 恐龍
            dino.dy += gravity;
            dino.y += dino.dy;
            if (dino.y > 220) {
                dino.y = 220;
                dino.dy = 0;
                dino.grounded = true;
            }
            ctx.fillStyle = "#1a73e8"; // Google Blue
            ctx.fillRect(dino.x, dino.y, dino.w, dino.h);

            // 障礙物
            obstacle.x -= obstacle.speed;
            if (obstacle.x < -30) {
                obstacle.x = 800 + Math.random() * 300;
                score++;
                obstacle.speed += 0.2;
                document.getElementById('game-score').innerText = "Score: " + score;
            }
            ctx.fillStyle = "#ea4335"; // Google Red
            ctx.fillRect(obstacle.x, obstacle.y, obstacle.w, obstacle.h);

            // 碰撞判定
            if (
                dino.x < obstacle.x + obstacle.w &&
                dino.x + dino.w > obstacle.x &&
                dino.y < obstacle.y + obstacle.h &&
                dino.y + dino.h > obstacle.y
            ) {
                isGameOver = true;
                gameRunning = false;
                ctx.fillStyle = "rgba(0,0,0,0.5)";
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = "white";
                ctx.font = "30px Roboto";
                ctx.fillText("Game Over!", 320, 150);
                
                // 顯示重來按鈕的邏輯 (簡單點擊畫布重來)
                canvas.onclick = resetGame;
            } else {
                canvas.onclick = null; // 遊戲中點擊無效(防止誤觸)
                requestAnimationFrame(updateGame);
            }
        }
        
        // 鍵盤輔助 (測試用)
        document.addEventListener('keydown', (e) => {
            if (e.code === 'Space') jump();
            if (e.code === 'KeyR' && isGameOver) resetGame();
        });

    </script>
</body>
</html>
